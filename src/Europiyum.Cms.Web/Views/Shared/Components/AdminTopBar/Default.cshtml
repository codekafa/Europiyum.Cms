@model Europiyum.Cms.Web.ViewComponents.AdminTopBarVm
<header class="cms-topbar d-flex align-items-center justify-content-between px-4 px-lg-5 py-3 gap-3 flex-wrap">
    <div>
        <h1 class="cms-page-title mb-0">@Model.Title</h1>
        @if (!string.IsNullOrEmpty(Model.Subtitle))
        {
            <p class="cms-page-subtitle mb-0 mt-1">@Model.Subtitle</p>
        }
    </div>
    <div class="d-flex align-items-center gap-3 flex-wrap">
        @if (Model.Companies.Count > 0)
        {
            <form asp-area="Admin" asp-controller="Workspace" asp-action="SelectCompany" method="post" class="d-flex align-items-center gap-2">
                @Html.AntiForgeryToken()
                <label class="small text-secondary mb-0">Şirket</label>
                <select name="companyId" class="form-select form-select-sm cms-select" onchange="this.form.submit()">
                    <option value="">Seçin…</option>
                    @foreach (var c in Model.Companies)
                    {
                        if (Model.SelectedCompanyId == c.Id)
                        {
                            <option value="@c.Id" selected>@c.Name</option>
                        }
                        else
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    }
                </select>
            </form>
            @if (Model.SelectedCompanyId is not null)
            {
                <form asp-area="Admin" asp-controller="Workspace" asp-action="ClearCompany" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-secondary">Temizle</button>
                </form>
            }
        }
        <span class="small text-secondary">@User.Identity?.Name</span>
    </div>
</header>
