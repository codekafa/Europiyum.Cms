@model IReadOnlyList<FormDefinitionListRowVm>
@{
    ViewData["Title"] = "Formlar";
    ViewData["Subtitle"] = "Sayfalara bağlanacak form tanımları";
    ViewData["HelpIntro"] = "Form, alan anahtarları ve türleriyle tanımlanır; sayfa düzenlemede seçildiğinde sitede basılır veya sayfa HTML’inizde aynı anahtarlarla özel form yazabilirsiniz.";
    ViewData["HelpBullets"] = new[]
    {
        "Gönderim adresi: /dil/forms/FORM_ANAHTARI/submit (CSRF ve honeypot için aşağıdaki ayrıntılara bakın).",
        "E-posta özetleri: Form düzenlemede bildirim seçeneği + E-posta (SMTP) ekranı."
    };
}
<partial name="_AdminScreenHelp" />
<div class="alert alert-light border small mb-3">
    <p class="mb-2 fw-medium">Örnek akış</p>
    <ol class="mb-0 ps-3">
        <li><strong>Formlar</strong> üzerinden <em>Yeni form</em> ile tanım oluşturun (görünen ad + URL anahtarı).</li>
        <li><strong>Form düzenle</strong> ekranında alanları ekleyin (metin, e-posta, liste, radyo vb.). Liste ve radyo için seçenekleri satır satır yazın.</li>
        <li><strong>Sayfalar → Düzenle</strong> içinde ilgili sayfaya bu formu bağlayın.</li>
        <li>Ziyaretçi sayfayı açtığında form görünür; gönderim <code>/{dil}/forms/{anahtar}/submit</code> adresine POST ile kaydedilir (<code>form_submissions</code>).</li>
    </ol>
    <p class="mb-0 mt-2 text-secondary">Sayfa–form bağlantısı koparılırsa <code>FormDefinitionId</code> null olur; form silinirse gönderimler ve alanlar silinir (sayfa bağlantısı otomatik temizlenir).</p>
    <p class="mb-0 mt-2"><strong>Özel HTML:</strong> Sayfa gövdesine kendi <code>&lt;form&gt;</code> etiketinizi yazabilirsiniz; <code>action="/%%CMS_LANG%%/forms/FORM_ANAHTARI/submit"</code>, <code>method="post"</code> ve gizli alan <code>&lt;input type="hidden" name="__RequestVerificationToken" value="%%CMS_ANTIFORGERY_TOKEN%%" /&gt;</code> kullanın. Alan <code>name</code> değerleri form tanımındaki alan anahtarlarıyla aynı olmalıdır (ör. <code>form_name</code>). İsteğe bağlı honeypot: boş bırakılan <code>form_botcheck</code>.</p>
</div>
<div class="cms-card p-3 mb-3 d-flex flex-wrap gap-2 justify-content-between align-items-center">
    <span class="small text-secondary">@Model.Count form</span>
    <a class="btn btn-primary" asp-action="Create">Yeni form</a>
</div>
<div class="cms-card overflow-hidden">
    <div class="table-responsive">
        <table class="table cms-table mb-0">
            <thead>
                <tr>
                    <th>Ad</th>
                    <th>Anahtar</th>
                    <th>Alan</th>
                    <th>Aktif</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="5" class="text-secondary p-4 text-center">Kayıt yok. Yeni form oluşturun.</td></tr>
            }
            else
            {
                foreach (var r in Model)
                {
                    <tr>
                        <td class="fw-medium">@r.Name</td>
                        <td><code>@r.Key</code></td>
                        <td>@r.FieldCount</td>
                        <td>@(r.IsActive ? "Evet" : "Hayır")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@r.Id">Düzenle</a>
                            <form asp-action="Delete" asp-route-id="@r.Id" method="post" class="d-inline" onsubmit="return confirm('Bu formu silmek istediğinize emin misiniz? Bağlı sayfalardaki form seçimi kaldırılır; gönderimler silinir.');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Sil</button>
                            </form>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>
