@model CompanyEditVm
@{
    ViewData["Title"] = "Şirket düzenle";
    ViewData["Subtitle"] = Model.Name;
    var langOpts = ViewBag.LanguageOptions as IReadOnlyList<LanguageOptionVm>;
    ViewData["HelpIntro"] = "Bu kayıt, public uygulamanın hangi şirketi yükleyeceğini (Code) ve varsayılan dili belirler. Kod değişirse site yapılandırmasıyla uyumlu olmalıdır.";
    ViewData["HelpBullets"] = new[]
    {
        "Anasayfa şablon anahtarı, Stratify’de hangi home görünümünün kullanılacağını seçer.",
        "Varsayılan dil, çevirisi eksik alanlarda yedek olarak kullanılır."
    };
}
<partial name="_AdminScreenHelp" />
<div class="cms-card p-4">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
        <input type="hidden" asp-for="Id" />
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label" asp-for="Name"></label>
                <input class="form-control" asp-for="Name" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="Code"></label>
                <input class="form-control" asp-for="Code" />
                <span asp-validation-for="Code" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="Slug"></label>
                <input class="form-control" asp-for="Slug" />
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="PrimaryDomain"></label>
                <input class="form-control" asp-for="PrimaryDomain" placeholder="www.ornek.com" />
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="HomepageVariantKey"></label>
                <input class="form-control" asp-for="HomepageVariantKey" placeholder="index, index-3, index-5-dark" />
                <div class="form-text">Stratify HTML dosya kökü ile eşleşir (ör. index-3 → Index3.cshtml).</div>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="DefaultLanguageId"></label>
                @if (langOpts is { Count: > 0 })
                {
                    <select class="form-select" asp-for="DefaultLanguageId"
                            asp-items="@(new SelectList(langOpts, nameof(LanguageOptionVm.Id), nameof(LanguageOptionVm.Name)))"></select>
                    <div class="form-text">Yalnızca <a asp-area="Admin" asp-controller="CompanyLanguages" asp-action="Index">site dillerinde</a> aktif olanlar listelenir.</div>
                }
                else
                {
                    <input class="form-control" type="number" asp-for="DefaultLanguageId" />
                    <div class="form-text text-warning">Aktif site dili yok. Önce site dillerinden en az bir dil ekleyin.</div>
                }
            </div>
            <div class="col-12">
                <div class="form-check">
                    <input class="form-check-input" asp-for="IsActive" />
                    <label class="form-check-label" asp-for="IsActive"></label>
                </div>
            </div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Kaydet</button>
            <a class="btn btn-outline-secondary" asp-action="Index">İptal</a>
        </div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
