@using Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] · Evropiyum CMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link href="~/cms/admin.css" rel="stylesheet" asp-append-version="true" />
</head>
<body class="cms-body">
    <div class="cms-app d-flex min-vh-100">
        <aside class="cms-sidebar d-flex flex-column">
            <div class="cms-brand px-4 py-4">
                <span class="cms-brand-mark">E</span>
                <div>
                    <div class="cms-brand-title">Evropiyum</div>
                    <div class="cms-brand-sub">Content Studio</div>
                </div>
            </div>
            <nav class="cms-nav flex-grow-1 px-3" aria-label="Ana menü">
                <a class="cms-nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index" title="Şirket seçin; çoğu işlem seçili şirkete göre çalışır.">Kontrol paneli</a>
                <a class="cms-nav-link" asp-area="Admin" asp-controller="Companies" asp-action="Index" title="Her site veya marka bir şirket kaydıdır: kod, domain, tema anahtarı.">Şirketler</a>
                <a class="cms-nav-link" asp-area="Admin" asp-controller="Languages" asp-action="Index" title="Projede tanımlı tüm diller; şirket hangilerini kullanacağını Site dillerinden seçer.">Dil kataloğu</a>
                <a class="cms-nav-link" asp-area="Admin" asp-controller="CompanyLanguages" asp-action="Index" title="Seçili şirketin yayın dilleri ve varsayılan dil.">Site dilleri</a>
                <a class="cms-nav-link" asp-area="Admin" asp-controller="Pages" asp-action="Index" title="İç sayfalar: slug, çeviri, form ve SEO; anasayfa tipi ayrıdır.">Sayfalar</a>
                <a class="cms-nav-link" asp-area="Admin" asp-controller="Menus" asp-action="Index" asp-route-kind="Header" title="Üst ve alt menü öğeleri; iç sayfa veya harici bağlantı.">Menüler</a>
                <a class="cms-nav-link" asp-area="Admin" asp-controller="SiteAppearance" asp-action="Index" title="Footer, logo, favicon, head script (Analytics), özel CSS, iletişim satırı.">Site görünümü</a>
                <a class="cms-nav-link" asp-area="Admin" asp-controller="MailSettings" asp-action="Index" title="Form bildirim e-postaları ve gönderen adresi için SMTP.">E-posta (SMTP)</a>
                <a class="cms-nav-link" asp-area="Admin" asp-controller="FormDefinitions" asp-action="Index" title="Alan tanımları; sayfaya bağlanır, gönderim veritabanına ve isteğe bağlı e-postaya gider.">Formlar</a>
                <a class="cms-nav-link" asp-area="Admin" asp-controller="Components" asp-action="Index" title="Tekrar kullanılabilir içerik blokları; sayfa veya anasayfa bölümüne bağlanır.">Bileşenler</a>
                <a class="cms-nav-link" asp-area="Admin" asp-controller="HomeSections" asp-action="Index" title="Ana sayfadaki hero, CTA vb. sabit bölgeler (şablon anahtarları).">Anasayfa bölümleri</a>
                <a class="cms-nav-link" asp-area="Admin" asp-controller="Media" asp-action="Index" title="Yüklenen görseller ve dosyalar; bileşen ve sayfalarda yol ile kullanılır.">Medya</a>
            </nav>
            <div class="px-3 pb-4 small text-secondary">
                <form asp-controller="Account" asp-action="Logout" asp-area="" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-link text-decoration-none p-0 text-secondary">Çıkış</button>
                </form>
            </div>
        </aside>
        <div class="cms-main flex-grow-1 d-flex flex-column">
            @await Component.InvokeAsync("AdminTopBar")
            <main class="cms-content flex-grow-1 px-4 px-lg-5 py-4">
                @if (TempData["Toast"] is string toast)
                {
                    <div class="alert alert-success border-0 shadow-sm cms-toast mb-4" role="alert">@toast</div>
                }
                @if (TempData["Error"] is string err)
                {
                    <div class="alert alert-danger border-0 shadow-sm cms-toast mb-4" role="alert">@err</div>
                }
                @RenderBody()
            </main>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
