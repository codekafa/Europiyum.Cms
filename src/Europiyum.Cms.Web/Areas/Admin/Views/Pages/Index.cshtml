@model IReadOnlyList<PageListItemVm>
@{
    ViewData["Title"] = "Sayfalar";
    ViewData["Subtitle"] = "Seçili şirket kapsamında";
    var filter = ViewBag.Filter as PageListFilterVm ?? new PageListFilterVm();
    ViewData["HelpIntro"] = "Sayfa, sitede bir URL (slug) ve dil başına başlık/HTML içerik taşır. İç sayfalar gövdeyi çeviri alanından alır; anasayfa tipi özel şablon ve bölümlerle çalışır.";
    ViewData["HelpBullets"] = new[]
    {
        "Bileşen: Sayfa listesinden Bileşen bağlantısı; anasayfada sıralı bloklar olarak görünür.",
        "Form: Sayfa düzenlemede form seçimi; iletişim gibi formlar Formlar menüsünde tanımlanır.",
        "SEO: Arama motoru meta alanları ayrı ekrandadır."
    };
}
<partial name="_AdminScreenHelp" />
<div class="cms-card p-4 mb-4">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-5">
            <label class="form-label small text-secondary mb-1">Ara (slug / başlık)</label>
            <input class="form-control" name="Search" value="@filter.Search" placeholder="ör. hakkimizda" />
        </div>
        <div class="col-md-3">
            <div class="form-check mt-4">
                <input type="hidden" name="ActiveOnly" value="false" />
                <input class="form-check-input" type="checkbox" name="ActiveOnly" value="true" id="activeOnly" checked="@filter.ActiveOnly" />
                <label class="form-check-label" for="activeOnly">Yalnızca aktif sayfalar</label>
            </div>
        </div>
        <div class="col-md-4 d-flex gap-2 justify-content-md-end">
            <button type="submit" class="btn btn-outline-secondary">Filtrele</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Sıfırla</a>
            <a class="btn btn-primary" asp-action="Create">Yeni sayfa</a>
        </div>
    </form>
</div>

<div class="cms-card overflow-hidden">
    <div class="cms-card-header d-flex justify-content-between align-items-center">
        <span>Sayfa listesi</span>
        <span class="small text-secondary">@Model.Count kayıt</span>
    </div>
    <div class="table-responsive">
        <table class="table cms-table mb-0">
            <thead>
                <tr>
                    <th>Başlık</th>
                    <th>Slug</th>
                    <th>Tip</th>
                    <th>Şablon</th>
                    <th>Sıra</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td class="fw-medium">@(p.TitlePreview ?? "—")</td>
                    <td><code>@p.Slug</code></td>
                    <td><span class="badge rounded-pill text-bg-light border">@p.PageType</span></td>
                    <td>@(p.TemplateKey ?? "—")</td>
                    <td>@p.SortOrder</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-area="Admin" asp-controller="PageAttachments" asp-action="Index" asp-route-pageId="@p.Id" title="Bileşenler">Bileşen</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@p.Id">Düzenle</a>
                        @if (p.PageType != PageType.Home)
                        {
                            <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline" onsubmit="return confirm('Bu sayfayı silmek istediğinize emin misiniz?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Sil</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
