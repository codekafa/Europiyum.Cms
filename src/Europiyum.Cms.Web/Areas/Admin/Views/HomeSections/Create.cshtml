@model HomeSectionCreateVm
@{
    ViewData["Title"] = "Yeni anasayfa bölümü";
    var comps = ViewBag.ComponentOptions as IReadOnlyList<ComponentListItemVm> ?? Array.Empty<ComponentListItemVm>();
    ViewData["HelpIntro"] = "Bölüm anahtarı (hero, about, …) temadaki yuvayla eşleşir. İsterseniz doğrudan HTML girersiniz, isterseniz mevcut bir bileşeni bağlarsınız.";
    ViewData["HelpBullets"] = new[]
    {
        "Aynı anahtardan yalnızca mantıklı sayıda kayıt kullanın; çakışmalar temaya göre değişir.",
        "Düzenle ekranında çeviri sekmeleri açılır."
    };
}
<partial name="_AdminScreenHelp" />
<div class="cms-card p-4" style="max-width: 640px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
        <input type="hidden" asp-for="CompanyId" />
        <div class="mb-3">
            <label class="form-label" asp-for="SectionKey"></label>
            <select class="form-select" asp-for="SectionKey">
                @foreach (var (key, label) in HomeSectionKeys.All)
                {
                    <option value="@key">@label (@key)</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="SortOrder"></label>
            <input class="form-control" type="number" asp-for="SortOrder" />
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="LinkedComponentItemId"></label>
            <select class="form-select" asp-for="LinkedComponentItemId">
                <option value="">— Bağlama —</option>
                @foreach (var c in comps)
                {
                    <option value="@c.Id">@c.TypeDisplayName — @(c.TitlePreview ?? ("#" + c.Id))</option>
                }
            </select>
        </div>
        <div class="mb-4 form-check">
            <input class="form-check-input" asp-for="IsActive" />
            <label class="form-check-label" asp-for="IsActive"></label>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Oluştur</button>
            <a class="btn btn-outline-secondary" asp-action="Index">İptal</a>
        </div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
