@model Europiyum.Cms.Application.Public.Models.SiteFooterViewModel
@{
    var content = "/_content/Europiyum.Web.Stratify/stratify";
    var homeHref = string.IsNullOrWhiteSpace(Model.LanguageCode)
        ? "/"
        : "/" + Uri.EscapeDataString(Model.LanguageCode.Trim());
    var logoUrl = string.IsNullOrWhiteSpace(Model.FooterLogoSrc)
        ? content + "/images/logo/logo-light.png"
        : Model.FooterLogoSrc;
}
@if (Model.RenderFullHtmlOnly && !string.IsNullOrWhiteSpace(Model.FooterFullHtml))
{
    @Html.Raw(Model.FooterFullHtml)
}
else
{
<footer class="footer-area">
    <div class="footer__shape-left">
        <img src="@content/images/shape/footer-shape-left.png" alt="" />
    </div>
    <div class="container">
        <div class="footer__wrp pt-130 pb-130">
            <div class="footer__left">
                <a href="@homeHref" class="logo">
                    <img src="@logoUrl" alt="@Model.SiteTitle" />
                </a>
                @if (!string.IsNullOrWhiteSpace(Model.IntroHtml))
                {
                    <div class="mt-30 cms-footer-intro">@Html.Raw(Model.IntroHtml)</div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.ContactEmail))
                {
                    <p class="text-white mt-3 mb-1"><a href="mailto:@Model.ContactEmail">@Model.ContactEmail</a></p>
                }
                @if (!string.IsNullOrWhiteSpace(Model.ContactPhone))
                {
                    <p class="text-white mb-0">@Model.ContactPhone</p>
                }
            </div>
            <div class="footer__right">
                @if (!string.IsNullOrWhiteSpace(Model.BodyHtml))
                {
                    <div class="cms-footer-body mt-80">@Html.Raw(Model.BodyHtml)</div>
                }
            </div>
        </div>
    </div>
    <div class="footer__copyright">
        <div class="container">
            <div class="d-flex flex-wrap align-items-center justify-content-center justify-content-lg-between gap-1 gap-sm-4">
                <div class="text-lg-start text-center">
                    @if (!string.IsNullOrWhiteSpace(Model.CopyrightHtml))
                    {
                        @Html.Raw(Model.CopyrightHtml)
                    }
                    else
                    {
                        <p class="mb-0">&copy; @DateTime.UtcNow.Year <a href="@homeHref">@Model.SiteTitle</a></p>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="footer__rectangle">
        <div class="item wow"></div>
        <div class="item-dark wow"></div>
    </div>
</footer>
}
