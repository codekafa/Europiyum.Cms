@model PublicPageFormVm
@{
    var lang = ViewData["LanguageCode"] as string ?? "tr";
    var actionUrl = "/" + Uri.EscapeDataString(lang.Trim()) + "/forms/" + Uri.EscapeDataString(Model.Key) + "/submit";
}
<div class="cms-page-form card border-0 shadow-sm mt-4">
    <div class="card-body p-4">
        <h2 class="h5 mb-3">@Model.Name</h2>
        @if (TempData["FormError"] is string ferr)
        {
            <div class="alert alert-danger">@ferr</div>
        }
        @if (TempData["FormOk"] is string fok)
        {
            <div class="alert alert-success">@fok</div>
        }
        <form method="post" action="@actionUrl">
            @Html.AntiForgeryToken()
            @foreach (var f in Model.Fields)
            {
                var id = "fld_" + f.FieldKey;
                var label = string.IsNullOrWhiteSpace(f.Label) ? f.FieldKey : f.Label;
                <div class="mb-3">
                    <label class="form-label" for="@id">@label@(f.IsRequired ? " *" : "")</label>
                    @switch (f.FieldType)
                    {
                        case FormFieldType.TextArea:
                            <textarea class="form-control" id="@id" name="@f.FieldKey" rows="4" @(f.IsRequired ? "required" : null)></textarea>
                            break;
                        case FormFieldType.Email:
                            <input class="form-control" type="email" id="@id" name="@f.FieldKey" @(f.IsRequired ? "required" : null) />
                            break;
                        case FormFieldType.Phone:
                            <input class="form-control" type="tel" id="@id" name="@f.FieldKey" autocomplete="tel" @(f.IsRequired ? "required" : null) />
                            break;
                        case FormFieldType.Select:
                            <select class="form-select" id="@id" name="@f.FieldKey" @(f.IsRequired ? "required" : null)>
                                @if (!f.IsRequired)
                                {
                                    <option value="">Seçiniz</option>
                                }
                                @foreach (var opt in f.Options)
                                {
                                    <option value="@opt">@opt</option>
                                }
                            </select>
                            break;
                        case FormFieldType.Radio:
                            {
                                var ri = 0;
                                foreach (var opt in f.Options)
                                {
                                    var rid = id + "_" + ri;
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="@rid" name="@f.FieldKey" value="@opt" @(f.IsRequired && ri == 0 ? "required" : null) />
                                        <label class="form-check-label" for="@rid">@opt</label>
                                    </div>
                                    ri++;
                                }
                            }
                            break;
                        case FormFieldType.Checkbox:
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="@id" name="@f.FieldKey" value="true" />
                                <label class="form-check-label" for="@id">@label</label>
                            </div>
                            break;
                        case FormFieldType.File:
                            <input class="form-control" type="file" id="@id" name="@f.FieldKey" disabled />
                            <span class="form-text small">Dosya yükleme yakında etkinleştirilecek.</span>
                            break;
                        default:
                            <input class="form-control" type="text" id="@id" name="@f.FieldKey" @(f.IsRequired ? "required" : null) />
                            break;
                    }
                </div>
            }
            <button type="submit" class="btn btn-primary">Gönder</button>
        </form>
    </div>
</div>
